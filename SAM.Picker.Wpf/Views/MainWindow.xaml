<Window x:Class="SAM.Picker.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SAM.Picker.Wpf.ViewModels"
        xmlns:models="clr-namespace:SAM.Picker.Wpf.Models"
        xmlns:localConverters="clr-namespace:SAM.Picker.Wpf.Converters"
        mc:Ignorable="d"
        Title="SAM Picker (WPF Preview)"
        Width="1100"
        Height="720"
        Background="{StaticResource Brush.Background}"
        Loaded="OnLoaded">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid Margin="24">
        <Grid.Resources>
            <vm:MainViewModel x:Key="DesignVm" />
            <localConverters:BoolToOwnedTextConverter x:Key="BoolToOwnedTextConverter" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center" Margin="0 0 0 16">
            <TextBlock Text="Steam Achievement Manager" FontSize="22" FontWeight="Bold" />
            <Border Width="10" />
            <TextBlock Style="{StaticResource MutedText}" VerticalAlignment="Bottom" Margin="4 0 0 2"
                       Text="WPF preview • modern dark theme" />
        </StackPanel>

        <!-- Search + Filters -->
        <DockPanel Grid.Row="1" Margin="0 0 0 12">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <ToggleButton Content="Normal"
                              Margin="0 0 8 0"
                              IsChecked="{Binding ShowNormal, Mode=TwoWay}" />
                <ToggleButton Content="Demo"
                              Margin="0 0 8 0"
                              IsChecked="{Binding ShowDemo, Mode=TwoWay}" />
                <ToggleButton Content="Mods"
                              Margin="0 0 8 0"
                              IsChecked="{Binding ShowMod, Mode=TwoWay}" />
                <ToggleButton Content="Junk"
                              IsChecked="{Binding ShowJunk, Mode=TwoWay}" />
            </StackPanel>
            <Border Background="{StaticResource Brush.SurfaceAlt}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Medium}"
                    Padding="10 8"
                    Width="320">
                <DockPanel>
                    <TextBlock Text="🔍" Margin="0 0 8 0" VerticalAlignment="Center" />
                    <TextBox BorderThickness="0"
                             Background="{StaticResource Brush.Transparent}"
                             Foreground="{StaticResource Brush.Text}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontStyle="Italic"
                             FontWeight="Normal"
                             ToolTip="Search games..." />
                </DockPanel>
            </Border>
        </DockPanel>

        <!-- Game grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredGames}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" ItemWidth="240" ItemHeight="120" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:GameItem}">
                        <Border Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Medium}"
                                Padding="12"
                                Width="220"
                                Height="110"
                                Margin="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Id}" Grid.Row="1" Style="{StaticResource MutedText}" />
                                <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Border Background="{StaticResource Brush.Primary}"
                                            CornerRadius="{StaticResource Radius.Small}"
                                            Padding="6 2"
                                            Margin="0 0 8 0">
                                        <TextBlock Text="{Binding Type}" Foreground="#0b1016" FontWeight="SemiBold" />
                                    </Border>
                                    <Border Background="{StaticResource Brush.SurfaceAlt}"
                                            CornerRadius="{StaticResource Radius.Small}"
                                            Padding="6 2">
                                        <TextBlock Text="{Binding Owned, Converter={StaticResource BoolToOwnedTextConverter}}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
