{
  "name": "steam-achievement-manager",
  "version": "8.0.0",
  "main": "dist-electron/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:service": "dotnet build ../SAM.Service/SAM.Service.csproj -c Release -p:Platform=x86",
    "prepackage": "npm run build:service",
    "package": "npm run build && electron-builder"
  },
  "keywords": ["steam", "achievements", "manager", "electron"],
  "author": "Steam Achievement Manager Contributors",
  "license": "GPL-3.0",
  "description": "Steam Achievement Manager - Manage achievements and statistics for Steam games",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.90.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "tailwind-merge": "^3.4.0"
  },
  "build": {
    "appId": "com.steam.achievementmanager",
    "productName": "Steam Achievement Manager",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "extraResources": [
      {
        "from": "../upload/net48",
        "to": "sam-service",
        "filter": ["SAM.Service.exe", "*.dll"]
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/*.ts",
      "!**/*.map"
    ]
  }
}
