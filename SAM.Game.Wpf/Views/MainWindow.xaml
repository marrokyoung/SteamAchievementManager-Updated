<Window x:Class="SAM.Game.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SAM.Game.Wpf.ViewModels"
        xmlns:models="clr-namespace:SAM.Game.Wpf.Models"
        xmlns:conv="clr-namespace:SAM.Game.Wpf.Converters"
        mc:Ignorable="d"
        Title="SAM Manager (WPF Preview)"
        Width="1200"
        Height="800"
        Background="{StaticResource Brush.Background}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:AchievementIconConverter x:Key="AchievementIconConverter" />
        <conv:AchievementIconVisibilityConverter x:Key="AchievementIconVisibilityConverter" />
    </Window.Resources>
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid Margin="24" Loaded="OnLoaded">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header / Commands -->
        <DockPanel Grid.Row="0" Grid.ColumnSpan="2" LastChildFill="True" Margin="0 0 0 16" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBlock Text="{Binding GameTitle}" FontSize="22" FontWeight="Bold" />
                <Border Width="10" />
                <TextBlock Style="{StaticResource MutedText}" VerticalAlignment="Bottom" Margin="4 0 0 2"
                           Text="WPF preview • modern dark theme" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="0 0 8 0" />
                <Button Content="Unlock All" Command="{Binding UnlockAllCommand}" Margin="0 0 8 0" />
                <Button Content="Lock All" Command="{Binding LockAllCommand}" Margin="0 0 8 0" />
                <Button Content="Store" Command="{Binding StoreCommand}" Margin="0 0 8 0" />
                <Button Content="Reset All" Command="{Binding ResetAllCommand}" />
            </StackPanel>
        </DockPanel>

        <!-- Achievements list -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Medium}"
                Padding="12"
                Margin="0 0 12 12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Achievements" FontSize="16" FontWeight="SemiBold" Margin="0 0 0 8" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Achievements}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:AchievementItem}">
                                <Border Background="{StaticResource Brush.SurfaceAlt}"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Medium}"
                                        Padding="10"
                                        Margin="0 6 0 6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{StaticResource Brush.Surface}"
                                                CornerRadius="{StaticResource Radius.Small}"
                                                Width="48" Height="48"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <Image Width="48" Height="48"
                                                   Source="{Binding Id, Converter={StaticResource AchievementIconConverter}, ConverterParameter={Binding RelativeSource={RelativeSource AncestorType=Window}}}"
                                                   Visibility="{Binding Id, Converter={StaticResource AchievementIconVisibilityConverter}, ConverterParameter={Binding RelativeSource={RelativeSource AncestorType=Window}}}" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding Unlocked}"
                                                          Margin="0 0 8 0"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource MutedText}" Margin="24 2 0 0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Stats panel -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Medium}"
                Padding="12"
                Margin="12 0 0 12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Statistics" FontSize="16" FontWeight="SemiBold" Margin="0 0 0 8" />
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Stats}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          RowHeaderWidth="0"
                          Background="{StaticResource Brush.SurfaceAlt}"
                          BorderBrush="{StaticResource Brush.Border}"
                          BorderThickness="1"
                          Foreground="{StaticResource Brush.Text}">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
                            <Setter Property="SnapsToDevicePixels" Value="True" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Background" Value="#33f85149" />
                                    <Setter Property="ToolTip" Value="{Binding Error}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasWarning}" Value="True">
                                    <Setter Property="Background" Value="#33f0c674" />
                                    <Setter Property="ToolTip" Value="{Binding Warning}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="2*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Width="*" />
                        <DataGridCheckBoxColumn Header="Protected" Binding="{Binding IsProtected}" IsReadOnly="True" Width="100" />
                        <DataGridCheckBoxColumn Header="Increment Only" Binding="{Binding IsIncrementOnly}" IsReadOnly="True" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Status bar -->
        <DockPanel Grid.Row="2" Grid.ColumnSpan="2" VerticalAlignment="Center">
            <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" />
                <Border Background="{Binding ToastSeverity, Converter={StaticResource ToastBrushConverter}}"
                        CornerRadius="{StaticResource Radius.Small}"
                        Padding="8 4"
                        Margin="0 4 0 0"
                        Visibility="{Binding ToastVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ToastMessage}" />
                </Border>
            </StackPanel>
            <ProgressBar Width="180" Height="6" Margin="12 0 0 0"
                         IsIndeterminate="{Binding IsBusy}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
        </DockPanel>
    </Grid>
</Window>
