{
  "name": "steam-achievement-manager",
  "version": "8.0.3",
  "main": "dist-electron/index.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:electron-runtime",
    "build:electron-runtime": "npx esbuild main/index.ts --bundle --platform=node --format=cjs --outfile=dist-electron/index.cjs --external:electron --external:electron-updater && npx esbuild preload/index.ts --bundle --platform=node --format=cjs --outfile=dist-electron/preload.cjs --external:electron",
    "test": "vitest",
    "test:run": "vitest run",
    "clean:dist": "node -e \"const fs=require('fs');['dist','dist-electron','release'].forEach(d=>{if(fs.existsSync(d)){fs.rmSync(d,{recursive:true,force:true});console.log('Removed '+d)}})\"",
    "build:service": "dotnet build ../SAM.Service/SAM.Service.csproj -c Release -p:Platform=x86",
    "build:service:dev": "dotnet build ../SAM.Service/SAM.Service.csproj -c Debug -p:Platform=x86",
    "build:service:all": "npm run build:service:dev && npm run build:service",
    "prepackage": "npm run build:service",
    "package": "npm run clean:dist && npm run build && electron-builder"
  },
  "keywords": [
    "steam",
    "achievements",
    "manager",
    "electron"
  ],
  "author": "Steam Achievement Manager Contributors",
  "license": "GPL-3.0",
  "description": "Steam Achievement Manager - Manage achievements and statistics for Steam games",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "electron": "^39.8.6",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.12",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.555.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "tailwind-merge": "^3.4.0"
  },
  "build": {
    "appId": "com.steam.achievementmanager",
    "productName": "Steam Achievement Manager",
    "artifactName": "Steam-Achievement-Manager-Setup.${ext}",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "marrokyoung",
      "repo": "SteamAchievementManager-Updated"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "extraResources": [
      {
        "from": "../upload/net48",
        "to": "sam-service",
        "filter": [
          "SAM.Service.exe",
          "*.config",
          "*.dll"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!dist/*.exe",
      "!dist/*.blockmap",
      "!dist/latest.yml",
      "!**/*.ts",
      "!**/*.map"
    ]
  }
}
